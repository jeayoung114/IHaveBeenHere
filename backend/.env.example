DATABASE_URL=sqlite+aiosqlite:///./food_log.db
GOOGLE_API_KEY=your_google_ai_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role key from Supabase dashboard → Project Settings → API>

# JWT Secret — used to verify Supabase Auth tokens on the backend.
# Find this in: Supabase dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=<your-jwt-secret>
