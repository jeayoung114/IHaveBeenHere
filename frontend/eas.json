{
  "cli": { "version": ">= 15.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development",
        "API_URL": "https://ihavebeenhere-production.up.railway.app"
      }
    },
    "development:simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "APP_ENV": "development",
        "API_URL": "https://ihavebeenhere-production.up.railway.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "staging",
        "API_URL": "https://ihavebeenhere-production.up.railway.app"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "ios": { "simulator": false },
      "android": { "buildType": "app-bundle" },
      "env": {
        "APP_ENV": "production",
        "API_URL": "https://ihavebeenhere-production.up.railway.app"
      }
    }
  },
  "submit": { "production": {} }
}
